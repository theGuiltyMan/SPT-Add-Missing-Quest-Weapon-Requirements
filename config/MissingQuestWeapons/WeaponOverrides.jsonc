  "customTypeRules": [
    {
      "comment": "Migrated from CustomCategories 'AKM'",
      "conditions": {
        "nameMatches": "\\b(AKM|AK-1|VPO|Draco)\\w*",
        "caliber": "Caliber762x39"
      },
      "type": "AKM",
      "alsoAs": []
    },
    {
      "comment": "Migrated from CustomCategories 'AKS-74U'",
      "conditions": {
        "nameMatches": "\\b(AKS-74U|SAG AK-545)\\w*"
      },
