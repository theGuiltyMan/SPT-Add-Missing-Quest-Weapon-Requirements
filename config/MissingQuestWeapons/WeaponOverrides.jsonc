      "conditions": {
        "nameMatches": "\\b(AK|Draco)\\w*"
      },
      "type": "AK",
      "alsoAs": []
    },
    {
      "comment": "Migrated from CustomCategories 'AK-74'",
      "conditions": {
        "nameMatches": "\\b(AK-74|AKS-74|SAG AK-545|Saiga SGL31|Saiga MK Ver. 030)\\w*",
        "not": {
          "nameMatches": "(\\b(AKS-74U)\\w*)"
        }
      },
      "type": "AK-74",
      "alsoAs": []
    },
    {
      "comment": "Migrated from CustomCategories 'AR-15'",
      "conditions": {
        "or": [
          {
            "nameMatches": "\\b(AR-15|M4A1|ATL-15)\\w*"
          },
          {
            "descriptionMatches": "\\b(AR-15|M4A1|ATL-15)\\w*"
          }
        ]
      },
      "type": "AR-15",
      "alsoAs": []
    },
    {
      "comment": "Migrated from CustomCategories 'M4A1'",
      "conditions": {
        "nameMatches": "\\b(M4A1|M416)\\w*"
      },
      "type": "M4A1",
      "alsoAs": []
    },
    {
      "comment": "Throwable grenades (frag, smoke, stun, flash). Excludes underbarrel launchers whose names also contain 'grenade'. Rolls up to 'explosive' via parentTypes.",
      "conditions": {
        "and": [
          { "nameMatches": "\\b(grenade)\\w*" },
          { "not": { "hasAncestor": "Launcher" } }
        ]
      },
      "type": "grenade",
      "alsoAs": []
    },
    {
      "comment": "Migrated from CustomCategories 'HK'",
      "conditions": {
        "or": [
          {
            "nameMatches": "\\b(HK|Heckler|Koch)\\w*"
          },
          {
            "descriptionMatches": "\\b(HK|Heckler|Koch)\\w*"
          }
        ],
        "not": {
          "or": [
            {
              "nameMatches": "(\\b(SR-|MCX|ACR)\\w*)"
