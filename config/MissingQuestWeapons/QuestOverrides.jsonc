  // Mod-group overrides (A3). Mod groups use intra-group AND, cross-group OR:
  //   "modsExpansionMode": "Auto" | "WhitelistOnly" | "NoExpansion"
  //     Auto           — singleton groups expand via type + aliases into new singleton
  //                      groups; multi-item groups kept verbatim (AND-bundles preserved).
  //     WhitelistOnly  — original field discarded; rebuilt as singleton groups from
  //                      includedMods alone.
  //     NoExpansion    — original groups kept verbatim; includedMods still appended.
  //   "includedMods":  ["attachmentId", "TypeName", ...]  appended as new singleton
  //                                                       groups (type names expand
  //                                                       to one singleton per member).
  //   "excludedMods":  ["attachmentId", "TypeName", ...]  applied last:
  //                      bare id    → drops any output group containing the id;
  //                      type name  → drops only groups whose members are entirely
  //                                   within that type (mixed bundles kept).
