{
  "version": 4,
  "enabled": true,
  "parentTypes": {
    "Revolver": "Pistol",
    "PumpActionShotgun": "Shotgun",
    "BoltActionSniperRifle": "SniperRifle",
    "grenade": "explosive",
    "Launcher": "explosive",
    "GrenadeLauncher": "explosive"
  },
  "excludedItems": [],
  "excludedWeaponTypes": [],
  "weaponLikeAncestors": ["Weapon", "Knife", "ThrowWeap", "Launcher"],
  // Per-entry cap on the cartesian product produced by includedModBundles /
  // excludedModBundles in QuestOverrides. Truncated + warned at startup.
  "modBundleCartesianCap": 500,
  "includeParentCategories": true,
  "bestCandidateExpansion": false,
  // 0 = Strip, 1 = KeepInDb (old `keepUnknownWeapons: true` equivalent), 2 = KeepAll (conservative)
  "unknownWeaponHandling": 2,
  "validateOverrideIds": false,
  "debug": false
}
